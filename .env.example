# Empfohlenes Standard-Setup: OpenRouter + nvidia/nemotron-3-ultra-550b-a55b:free (kostenlos)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="nvidia/nemotron-3-ultra-550b-a55b:free"

# Alternative 1: Google AI Studio + Gemini 2.0 Flash
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# OpenAI-kompatibles Routing fuer Tools wie Cline - Verwendung von Gemini
#OPENAI_API_KEY="${GEMINI_API_KEY}"
#OPENAI_API_BASE="https://generativelanguage.googleapis.com/v1beta/openai"
#OPENAI_MODEL="gemini-2.0-flash"

# OpenAI-kompatibles Routing fuer Tools wie Cline - Verwendung von OpenRouter
OPENAI_API_KEY="${OPENROUTER_API_KEY}"
OPENAI_API_BASE="https://openrouter.ai/api/v1"
OPENAI_MODEL="${OPENROUTER_MODEL}"

# Alternative 2: GitHub Models (GitHub Token noetig)
GITHUB_TOKEN=""
GITHUB_MODELS_BASE="https://models.inference.ai.azure.com"
GITHUB_MODELS_MODEL="gpt-4o-mini"

# Alternative 3: Anthropic (kostenpflichtig)
ANTHROPIC_API_KEY=""

# Alternative 4: Lokal ohne Cloud (Ollama)
OLLAMA_HOST="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen3:8b"
