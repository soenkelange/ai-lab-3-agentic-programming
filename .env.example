# Standard fuer den Workshop: Google AI Studio + Gemini 2.0 Flash
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# OpenAI-kompatibles Routing fuer Tools wie Aider
OPENAI_API_KEY="${GEMINI_API_KEY}"
OPENAI_API_BASE="https://generativelanguage.googleapis.com/v1beta/openai"
OPENAI_MODEL="gemini-2.0-flash"

# Freie Alternative 1: GitHub Models (GitHub Token noetig)
GITHUB_TOKEN=""
GITHUB_MODELS_BASE="https://models.inference.ai.azure.com"
GITHUB_MODELS_MODEL="gpt-4o-mini"

# Freie Alternative 2: OpenRouter (kostenlose Community-Modelle)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="qwen/qwen3-coder:free"

# Lokale Alternative ohne Cloud
OLLAMA_HOST="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen3:8b"
