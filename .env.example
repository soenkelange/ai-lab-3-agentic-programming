OPENAI_MODEL="openrouter/qwen/qwen3-coder"

# Freie Alternative 1: GitHub Models (GitHub Token noetig)
GITHUB_TOKEN=""
GITHUB_MODELS_BASE="https://models.inference.ai.azure.com"
GITHUB_MODELS_MODEL="gpt-4o-mini"

# Lokale Alternative ohne Cloud
OLLAMA_HOST="http://127.0.0.1:11434"
